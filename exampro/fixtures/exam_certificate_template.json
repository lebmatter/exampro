 {
  "doctype": "Exam Certificate Template",
  "name": "ExamPro Default Certificate",
  "title": "ExamPro Default Certificate",
  "html_template": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  @page {\n    size: A4 landscape;\n    margin: 0;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: Georgia, 'Times New Roman', serif;\n    background: #fff;\n    width: 297mm;\n    height: 210mm;\n    display: flex;\n    align-items: stretch;\n  }\n\n  .page {\n    width: 100%;\n    height: 100%;\n    padding: 14mm;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: space-between;\n  }\n\n  /* Outer border */\n  .page::before {\n    content: '';\n    position: absolute;\n    inset: 8mm;\n    border: 2.5pt solid #1a3a5c;\n  }\n\n  /* Inner border */\n  .page::after {\n    content: '';\n    position: absolute;\n    inset: 11mm;\n    border: 0.75pt solid #1a3a5c;\n  }\n\n  .header {\n    text-align: center;\n    padding-top: 4mm;\n    z-index: 1;\n  }\n\n  .logo-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    width: 100%;\n    padding: 0 14mm;\n  }\n\n  .partner-logo-wrap {\n    display: flex;\n    align-items: center;\n    min-width: 32mm;\n  }\n\n  .partner-logo-wrap img {\n    max-height: 14mm;\n    max-width: 40mm;\n    object-fit: contain;\n  }\n\n  .cert-label {\n    font-size: 9pt;\n    letter-spacing: 3.5pt;\n    text-transform: uppercase;\n    color: #1a3a5c;\n    margin-bottom: 1.5mm;\n  }\n\n  .cert-title {\n    font-size: 26pt;\n    color: #1a3a5c;\n    letter-spacing: 1.5pt;\n    font-weight: normal;\n    line-height: 1.15;\n  }\n\n  .divider {\n    width: 48mm;\n    height: 1.2pt;\n    background: #c9a84c;\n    margin: 3mm auto;\n  }\n\n  .body {\n    text-align: center;\n    z-index: 1;\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 0 18mm;\n  }\n\n  .presented-to {\n    font-size: 9pt;\n    letter-spacing: 2pt;\n    text-transform: uppercase;\n    color: #555;\n    margin-bottom: 3mm;\n  }\n\n  .candidate-name {\n    font-size: 30pt;\n    color: #1a1a1a;\n    font-style: italic;\n    line-height: 1.2;\n    margin-bottom: 4mm;\n  }\n\n  .achievement-text {\n    font-size: 10pt;\n    color: #444;\n    line-height: 1.7;\n    margin-bottom: 2mm;\n  }\n\n  .exam-title {\n    font-size: 13pt;\n    color: #1a3a5c;\n    font-weight: bold;\n    margin-bottom: 4mm;\n  }\n\n  .score-row {\n    display: flex;\n    gap: 10mm;\n    justify-content: center;\n    font-size: 8.5pt;\n    color: #555;\n  }\n\n  .score-row span {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 0.5mm;\n  }\n\n  .score-row strong {\n    font-size: 12pt;\n    color: #1a3a5c;\n  }\n\n  .footer {\n    width: 100%;\n    padding: 0 18mm 4mm;\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n    z-index: 1;\n  }\n\n  .footer-item {\n    text-align: center;\n  }\n\n  .footer-label {\n    font-size: 7pt;\n    letter-spacing: 1.5pt;\n    text-transform: uppercase;\n    color: #888;\n    margin-top: 1.5mm;\n  }\n\n  .footer-value {\n    font-size: 9pt;\n    color: #333;\n    margin-bottom: 1mm;\n  }\n\n  .footer-line {\n    width: 40mm;\n    height: 0.5pt;\n    background: #aaa;\n    margin: 0 auto;\n  }\n\n  .cert-id {\n    font-size: 7pt;\n    color: #aaa;\n    letter-spacing: 0.5pt;\n    font-family: 'Courier New', monospace;\n  }\n\n  .seal {\n    width: 18mm;\n    height: 18mm;\n    border-radius: 50%;\n    border: 2pt solid #c9a84c;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 6pt;\n    letter-spacing: 1pt;\n    text-transform: uppercase;\n    color: #c9a84c;\n    text-align: center;\n    padding: 2mm;\n    line-height: 1.4;\n  }\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <!-- Top row: partner logo (left) + cert header (centre) + seal (right) -->\n  <div class=\"logo-row\">\n    <div class=\"partner-logo-wrap\">\n      {% if partner_logo %}\n      <img src=\"{{ partner_logo }}\" alt=\"{{ partner_name }}\">\n      {% endif %}\n    </div>\n\n    <div class=\"header\">\n      <div class=\"cert-label\">ExamPro</div>\n      <div class=\"cert-title\">Certificate of Achievement</div>\n      <div class=\"divider\"></div>\n    </div>\n\n    <div style=\"min-width:32mm;display:flex;justify-content:flex-end;\">\n      <div class=\"seal\">Certified<br>Passed</div>\n    </div>\n  </div>\n\n  <!-- Body -->\n  <div class=\"body\">\n    <div class=\"presented-to\">This certificate is presented to</div>\n    <div class=\"candidate-name\">{{ student_name }}</div>\n    <div class=\"achievement-text\">\n      for successfully completing the examination\n    </div>\n    <div class=\"exam-title\">{{ exam_title }}</div>\n    <div class=\"score-row\">\n      <span><strong>{{ score }}%</strong>Score</span>\n      <span><strong>{{ marks_obtained }} / {{ total_marks }}</strong>Marks</span>\n      <span><strong>{{ exam_duration }}</strong>Duration</span>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div class=\"footer\">\n    <div class=\"footer-item\">\n      <div class=\"footer-line\"></div>\n      <div class=\"footer-label\">Authorised Signature</div>\n    </div>\n    <div style=\"text-align:center;\">\n      <div class=\"cert-id\">ID: {{ certificate_id }}</div>\n      <div style=\"font-size:7.5pt;color:#999;margin-top:0.5mm;\">Issued {{ issue_date }}</div>\n    </div>\n    <div class=\"footer-item\">\n      <div class=\"footer-value\">{{ completion_date }}</div>\n      <div class=\"footer-line\"></div>\n      <div class=\"footer-label\">Date of Completion</div>\n    </div>\n  </div>\n\n</div>\n</body>\n</html>",
